{
  "name": "ai-deployment-calculator-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "api:lint": "spectral lint \"**/*.{json,yaml,yml}\" --fail-severity=warn",
    "build": "vite build",
    "deps": "npm run deps:audit && npm run deps:signatures && npm run deps:lockfile && npm run deps:versions",
    "deps:audit": "npm audit --audit-level=high",
    "deps:lockfile": "lockfile-lint --path package-lock.json --type npm --allowed-hosts npm --validate-https",
    "deps:signatures": "npm audit signatures",
    "deps:versions": "syncpack lint",
    "dev": "vite --host 127.0.0.1",
    "format:check": "prettier . --check",
    "format:write": "prettier . --write",
    "gate": "npm run format:check && npm run lint && npm run typecheck && npm run json:check && npm run security && npm run build && npm run test && cd .. && .venv/bin/harness gate",
    "gate:api": "npm run gate && npm run api:lint",
    "harness:gate": "node --experimental-strip-types harness/cli.ts gate",
    "harness:preflight": "node --experimental-strip-types harness/cli.ts preflight",
    "json:check": "npm run json:format:check && npm run json:lint && npm run json:biome && npm run json:schema:compile && npm run json:schema && npm run json:package",
    "json:biome": "biome lint .",
    "json:format:check": "prettier \"**/*.{json,jsonc,json5}\" --check",
    "json:format:write": "prettier \"**/*.{json,jsonc,json5}\" --write",
    "json:lint": "eslint \"**/*.{json,jsonc,json5}\" --max-warnings=0",
    "json:package": "npmPkgJsonLint .",
    "json:schema": "node scripts/validate-json.mjs",
    "json:schema:compile": "ajv compile -s \"schemas/**/*.schema.json\" --spec=draft2020 --strict=true --all-errors -c ajv-formats -c ajv-keywords",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:dead && npm run lint:arch && npm run lint:spell",
    "lint:arch": "depcruise src --config .dependency-cruiser.cjs --output-type err",
    "lint:css": "stylelint \"src/**/*.css\" --max-warnings=0",
    "lint:dead": "knip",
    "lint:fix": "npx eslint . --fix",
    "lint:html": "markuplint \"**/*.html\"",
    "lint:js": "eslint . --max-warnings=0",
    "lint:js:preflight": "eslint src harness --max-warnings=0",
    "lint:spell": "cspell . --no-progress --no-summary",
    "preview": "vite preview --host 127.0.0.1",
    "security": "npm run security:sast && npm run security:secrets && npm run deps",
    "security:sast": "semgrep scan --config=p/typescript --config=p/javascript --config=p/security-audit --error --metrics=off",
    "security:secrets": "secretlint \"**/*\"",
    "setup:e2e": "playwright install --with-deps",
    "test": "npm run test:coverage && npm run test:e2e",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:harness": "vitest run --config harness/vitest.config.ts --coverage",
    "test:related": "vitest --run --related",
    "test:r": "npm run test:related --",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "latest",
    "ajv-formats": "latest",
    "ajv-keywords": "latest",
    "secure-json-parse": "latest"
  },
  "devDependencies": {
    "@axe-core/playwright": "latest",
    "@biomejs/biome": "latest",
    "@eslint/js": "latest",
    "@eslint/json": "latest",
    "@playwright/test": "latest",
    "@secretlint/secretlint-rule-preset-recommend": "latest",
    "@stoplight/spectral-cli": "latest",
    "@types/node": "latest",
    "@vitest/coverage-v8": "latest",
    "ajv-cli": "latest",
    "cspell": "latest",
    "dependency-cruiser": "latest",
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "eslint-import-resolver-node": "latest",
    "eslint-plugin-import-x": "latest",
    "eslint-plugin-jsdoc": "latest",
    "eslint-plugin-n": "latest",
    "eslint-plugin-no-only-tests": "latest",
    "eslint-plugin-promise": "latest",
    "eslint-plugin-regexp": "latest",
    "eslint-plugin-security": "latest",
    "eslint-plugin-sonarjs": "latest",
    "eslint-plugin-unicorn": "latest",
    "globals": "latest",
    "jsdom": "latest",
    "knip": "latest",
    "lockfile-lint": "latest",
    "npm-package-json-lint": "latest",
    "prettier": "latest",
    "secretlint": "latest",
    "stylelint": "latest",
    "stylelint-config-standard": "latest",
    "syncpack": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "latest",
    "vitest": "latest"
  },
  "overrides": {
    "fast-json-patch": "3.1.1"
  },
  "npmpackagejsonlint": {
    "rules": {
      "dependencies-type": "error",
      "devDependencies-type": "error",
      "engines-type": "error",
      "name-type": "error",
      "no-archive-dependencies": "error",
      "no-archive-devDependencies": "error",
      "no-duplicate-properties": "error",
      "no-file-dependencies": "error",
      "no-file-devDependencies": "error",
      "no-git-dependencies": "error",
      "no-git-devDependencies": "error",
      "no-repeated-dependencies": "error",
      "prefer-alphabetical-dependencies": "error",
      "prefer-alphabetical-devDependencies": "error",
      "prefer-no-engineStrict": "error",
      "private-type": "error",
      "require-engines": "error",
      "require-name": "error",
      "require-private": "error",
      "require-scripts": "error",
      "require-type": "error",
      "scripts-type": "error",
      "type-type": "error",
      "valid-values-private": [
        "error",
        [
          true
        ]
      ],
      "valid-values-type": [
        "error",
        [
          "module"
        ]
      ]
    }
  }
}
