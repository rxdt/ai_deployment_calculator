{
  "name": "ai-deployment-calculator-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "harness": "./harness/harness.mjs"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite --host 127.0.0.1",
    "format": "prettier . --check",
    "gate": "npm run preflight && npm run lint && npm run typecheck && npm run security && npm run build && npm run TEST && cd .. && .venv/bin/harness gate",
    "lint": "eslint . --max-warnings=0 && stylelint \"src/**/*.css\" --max-warnings=0 && markuplint \"**/*.html\" && biome lint . && ajv compile -s \"schemas/**/*.schema.json\" --spec=draft2020 --strict=true --all-errors -c ajv-formats -c ajv-keywords && node scripts/validate-json.mjs && npmPkgJsonLint . && depcruise src --config .dependency-cruiser.cjs --output-type err && knip && cspell . --no-progress --no-summary && spectral lint ci.yml ../.github/workflows/ci.yml --fail-severity=warn",
    "preflight": "npm run format && eslint src harness --max-warnings=0",
    "preview": "vite preview --host 127.0.0.1",
    "security": "semgrep scan --config=p/typescript --config=p/javascript --config=p/security-audit --error --metrics=off && secretlint \"**/*\" && npm audit --audit-level=high && npm audit signatures && lockfile-lint --path package-lock.json --type npm --allowed-hosts npm --validate-https && syncpack lint",
    "setup:e2e": "playwright install --with-deps",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "TEST": "vitest run --coverage && vitest run --config harness/vitest.config.ts --coverage && playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "latest",
    "ajv-formats": "latest",
    "ajv-keywords": "latest",
    "secure-json-parse": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "latest",
    "@biomejs/biome": "latest",
    "@eslint/js": "latest",
    "@eslint/json": "latest",
    "@playwright/test": "latest",
    "@secretlint/secretlint-rule-preset-recommend": "latest",
    "@stoplight/spectral-cli": "latest",
    "@types/node": "latest",
    "@vitest/coverage-v8": "latest",
    "ajv-cli": "latest",
    "cspell": "latest",
    "dependency-cruiser": "latest",
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "eslint-import-resolver-node": "latest",
    "eslint-plugin-import-x": "latest",
    "eslint-plugin-jsdoc": "latest",
    "eslint-plugin-n": "latest",
    "eslint-plugin-no-only-tests": "latest",
    "eslint-plugin-promise": "latest",
    "eslint-plugin-regexp": "latest",
    "eslint-plugin-security": "latest",
    "eslint-plugin-sonarjs": "latest",
    "eslint-plugin-unicorn": "latest",
    "globals": "latest",
    "jsdom": "latest",
    "knip": "latest",
    "lockfile-lint": "latest",
    "markuplint": "latest",
    "npm-package-json-lint": "latest",
    "prettier": "latest",
    "secretlint": "latest",
    "stylelint": "latest",
    "stylelint-config-standard": "latest",
    "syncpack": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "latest",
    "vitest": "latest"
  },
  "overrides": {
    "fast-json-patch": "3.1.1"
  },
  "npmpackagejsonlint": {
    "rules": {
      "dependencies-type": "error",
      "devDependencies-type": "error",
      "engines-type": "error",
      "name-type": "error",
      "no-archive-dependencies": "error",
      "no-archive-devDependencies": "error",
      "no-duplicate-properties": "error",
      "no-file-dependencies": "error",
      "no-file-devDependencies": "error",
      "no-git-dependencies": "error",
      "no-git-devDependencies": "error",
      "no-repeated-dependencies": "error",
      "prefer-alphabetical-dependencies": "error",
      "prefer-alphabetical-devDependencies": "error",
      "prefer-no-engineStrict": "error",
      "private-type": "error",
      "require-engines": "error",
      "require-name": "error",
      "require-private": "error",
      "require-scripts": "error",
      "require-type": "error",
      "scripts-type": "error",
      "type-type": "error",
      "valid-values-private": [
        "error",
        [
          true
        ]
      ],
      "valid-values-type": [
        "error",
        [
          "module"
        ]
      ]
    }
  }
}
