{
  "name": "ai-deployment-calculator-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "lint:js": "eslint .",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint": "npm run lint:js && npm run lint:css",
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:real": "playwright test --config playwright.real-api.config.ts",
    "gate": "npm run build && npm run test:coverage && npm run test:e2e && npm run test:e2e:real"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@playwright/test": "latest",
    "@vitest/coverage-v8": "latest",
    "eslint": "latest",
    "eslint-plugin-jsx-a11y": "latest",
    "eslint-plugin-react": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "eslint-plugin-security": "latest",
    "eslint-plugin-tailwindcss": "latest",
    "globals": "latest",
    "jsdom": "latest",
    "stylelint": "latest",
    "stylelint-config-standard": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
